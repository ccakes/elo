# Fastfile for Elo — Tauri iOS app.
#
# The actual compile is driven by `cargo tauri ios build` (NOT gym/xcodebuild),
# because the Rust build-script phase relies on setup the Tauri CLI performs.
# fastlane's job here is: auth, code-signing material, build-number bump, and
# the TestFlight upload.

default_platform(:ios)

# Repo root is one level up from the fastlane/ directory.
REPO_ROOT       = File.expand_path("..", __dir__)
APPLE_DIR       = File.join(REPO_ROOT, "crates/elo-tauri/gen/apple")
INFO_PLIST      = File.join(APPLE_DIR, "elo-tauri_iOS/Info.plist")
PROJECT_YML     = File.join(APPLE_DIR, "project.yml")
APP_IDENTIFIER  = "co.nurve.elo.calculator"
PROFILE_NAME    = "Elo AppStore"

platform :ios do
  desc "Build and upload a build to TestFlight"
  lane :beta do
    # --- Auth: App Store Connect API key (no Apple ID / 2FA needed) ---
    # Reads ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH from the environment.
    key = app_store_connect_api_key(
      key_id:      ENV.fetch("ASC_KEY_ID"),
      issuer_id:   ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house:    false,
    )

    # --- Code signing: ensure a distribution cert + an App Store profile ---
    # `cert`/`sigh` create-or-reuse material on the portal and install it into
    # the login keychain. The profile name is fixed so it matches the
    # PROVISIONING_PROFILE_SPECIFIER baked into project.yml / ExportOptions.plist.
    cert(api_key: key)
    sigh(
      api_key:          key,
      app_identifier:   APP_IDENTIFIER,
      provisioning_name: PROFILE_NAME,
      platform:         "ios",
    )

    # --- Build number: next TestFlight build number for this version ---
    latest = latest_testflight_build_number(
      api_key:        key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    )
    build_number = (latest + 1).to_s
    set_build_number(build_number)
    UI.message("Building TestFlight build number #{build_number}")

    # --- Compile via the Tauri CLI (this runs the Rust build + archive/export) ---
    Dir.chdir(REPO_ROOT) do
      sh("cargo", "tauri", "ios", "build", "--export-method", "app-store-connect")
    end

    # --- Locate the exported IPA and upload ---
    ipa = Dir[File.join(APPLE_DIR, "build/**/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found under #{APPLE_DIR}/build") if ipa.nil?
    UI.success("Found IPA: #{ipa}")

    upload_to_testflight(
      api_key:    key,
      ipa:        ipa,
      skip_waiting_for_build_processing: true,
    )
  end
end

# CFBundleVersion is written in two places that can each be authoritative
# depending on whether xcodegen regenerates the project during the build, so set
# both: the generated Info.plist and the project.yml it is generated from.
def set_build_number(build_number)
  sh("/usr/libexec/PlistBuddy", "-c",
     "Set :CFBundleVersion #{build_number}", INFO_PLIST)
  text = File.read(PROJECT_YML)
  text = text.gsub(/CFBundleVersion: ".*?"/, %(CFBundleVersion: "#{build_number}"))
  File.write(PROJECT_YML, text)
end
