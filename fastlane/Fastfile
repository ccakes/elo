# Fastfile for Elo — Tauri iOS app.
#
# The compile is driven by `cargo tauri ios build` (NOT gym/xcodebuild): the Rust
# build-script phase relies on setup the Tauri CLI performs. Signing is split:
#   - ARCHIVE: Manual signing is baked into gen/apple/project.yml's release config
#     (Apple Distribution + the "Elo AppStore" profile). Tauri patches in
#     DEVELOPMENT_TEAM but does not re-run xcodegen, so that config survives.
#   - EXPORT:  gen/apple/ExportOptions.plist (manual) makes Tauri's export embed
#     the profile and re-sign with the real cert.
# fastlane prepares the cert/profile, then AFTER the build re-signs the IPA to set
# a unique CFBundleVersion (Tauri forces CFBundleVersion == tauri.conf version
# during the build, so it can only be set post-export — which requires re-signing).

default_platform(:ios)

REPO_ROOT      = File.expand_path("..", __dir__)
APPLE_DIR      = File.join(REPO_ROOT, "crates/elo-tauri/gen/apple")
TAURI_CONF     = File.join(REPO_ROOT, "crates/elo-tauri/tauri.conf.json")
APP_IDENTIFIER = "co.nurve.elo.calculator"
TEAM_ID        = "C2RZM372M3"

platform :ios do
  desc "Build and upload a build to TestFlight"
  lane :beta do
    # --- Auth for the fastlane actions (build-number lookup + upload) ---
    # Reads ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH from the environment.
    key = app_store_connect_api_key(
      key_id:       ENV.fetch("ASC_KEY_ID"),
      issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house:     false,
    )

    # Lets Tauri stamp the team into the Xcode project so the archive succeeds.
    ENV["APPLE_DEVELOPMENT_TEAM"] = TEAM_ID

    # --- Code signing material: distribution cert + the "Elo AppStore" profile ---
    # Written to a gitignored dir so nothing secret lands in the repo. The names
    # match ExportOptions.plist / project.yml so Tauri's export step uses them.
    signing_dir = File.join(REPO_ROOT, "fastlane/.signing")
    cert(api_key: key, output_path: signing_dir)
    sigh(
      api_key:           key,
      app_identifier:    APP_IDENTIFIER,
      provisioning_name: "Elo AppStore",
      platform:          "ios",
      output_path:       signing_dir,
    )
    # sigh returns the profile UUID; the file path is in lane_context.
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]

    # --- Compile via the Tauri CLI (runs the Rust build + archive + export) ---
    Dir.chdir(REPO_ROOT) do
      sh("cargo", "tauri", "ios", "build", "--export-method", "app-store-connect")
    end

    ipa = Dir[File.join(APPLE_DIR, "build/**/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found under #{APPLE_DIR}/build") if ipa.nil?

    # --- Unique build number: <short>.<n>, e.g. 0.3.1 -> 0.3.1.1, 0.3.1.2 ---
    # Tauri set CFBundleVersion == short version during the build; bump it to the
    # next 4th-component value and re-sign the IPA (changing Info.plist breaks the
    # signature, so a resign is required).
    short  = JSON.parse(File.read(TAURI_CONF)).fetch("version") # e.g. "0.3.1"
    latest = latest_testflight_build_number(
      api_key:              key,
      app_identifier:       APP_IDENTIFIER,
      version:              short,
      initial_build_number: "#{short}.0",
    ).to_s
    next_n        = (latest.split(".")[3] || "0").to_i + 1
    bundle_version = "#{short}.#{next_n}"
    UI.message("Setting CFBundleVersion #{bundle_version} (short version #{short})")

    resign(
      ipa:                  ipa,
      signing_identity:     distribution_identity,
      provisioning_profile: profile_path,
      bundle_version:       bundle_version,
      use_app_entitlements: true,
    )

    upload_to_testflight(
      api_key:                           key,
      ipa:                               ipa,
      skip_waiting_for_build_processing: true,
    )
  end
end

# The full codesigning identity name (avoids hardcoding the team member's name).
def distribution_identity
  line = `security find-identity -v -p codesigning`.lines.find { |l| l.include?("Apple Distribution") }
  UI.user_error!("No 'Apple Distribution' identity in keychain") unless line
  line[/"([^"]+)"/, 1]
end
