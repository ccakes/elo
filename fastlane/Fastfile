# Fastfile for Elo — Tauri iOS app.
#
# The compile is driven by `cargo tauri ios build` (NOT gym/xcodebuild): the Rust
# build-script phase relies on setup the Tauri CLI performs, and Tauri patches the
# Xcode project's signing settings itself on every build. So fastlane does NOT
# manage signing here — instead we hand Tauri the App Store Connect API key via the
# APPLE_* env vars it reads, and it auto-provisions through xcodebuild
# `-allowProvisioningUpdates`. fastlane's remaining jobs: build-number bump and the
# TestFlight upload.

default_platform(:ios)

# Repo root is one level up from the fastlane/ directory.
REPO_ROOT       = File.expand_path("..", __dir__)
APPLE_DIR       = File.join(REPO_ROOT, "crates/elo-tauri/gen/apple")
INFO_PLIST      = File.join(APPLE_DIR, "elo-tauri_iOS/Info.plist")
APP_IDENTIFIER  = "co.nurve.elo.calculator"
TEAM_ID         = "C2RZM372M3"

platform :ios do
  desc "Build and upload a build to TestFlight"
  lane :beta do
    # --- Auth for the fastlane actions (build-number lookup + upload) ---
    # Reads ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH from the environment.
    key = app_store_connect_api_key(
      key_id:       ENV.fetch("ASC_KEY_ID"),
      issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
      in_house:     false,
    )

    # APPLE_DEVELOPMENT_TEAM lets Tauri stamp the team into the Xcode project so
    # the *archive* step succeeds. (Tauri's export step does not forward the API
    # key to xcodebuild, so automatic provisioning can't fetch a profile there —
    # hence we sign the export manually below.)
    ENV["APPLE_DEVELOPMENT_TEAM"] = TEAM_ID

    # --- Code signing: ensure a distribution cert + install the App Store ---
    # profile locally, named to match ExportOptions.plist's provisioningProfiles
    # mapping. The Tauri export step re-signs the archive with these.
    signing_dir = File.join(REPO_ROOT, "fastlane/.signing")
    cert(api_key: key, output_path: signing_dir)
    sigh(
      api_key:           key,
      app_identifier:    APP_IDENTIFIER,
      provisioning_name: "Elo AppStore",
      platform:          "ios",
      output_path:       signing_dir,
    )

    # --- Build number: next TestFlight build number for this version ---
    build_number = (latest_testflight_build_number(
      api_key:              key,
      app_identifier:       APP_IDENTIFIER,
      initial_build_number: 0,
    ) + 1).to_s
    UI.message("Building TestFlight build number #{build_number}")
    set_info_plist_value(path: INFO_PLIST, key: "CFBundleVersion", value: build_number)

    # --- Compile via the Tauri CLI (runs the Rust build + archive/export) ---
    Dir.chdir(REPO_ROOT) do
      sh("cargo", "tauri", "ios", "build", "--export-method", "app-store-connect")
    end

    # --- Locate the exported IPA and upload ---
    ipa = Dir[File.join(APPLE_DIR, "build/**/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("No .ipa found under #{APPLE_DIR}/build") if ipa.nil?
    UI.success("Found IPA: #{ipa}")

    upload_to_testflight(
      api_key:                           key,
      ipa:                               ipa,
      skip_waiting_for_build_processing: true,
    )
  end
end
