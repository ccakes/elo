# Copy to fastlane/.env and fill in. Do NOT commit fastlane/.env or the .p8 key.
# Create the key at App Store Connect → Users and Access → Integrations →
# App Store Connect API. Give it the "App Manager" role.

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Absolute path to the downloaded AuthKey_XXXXXXXXXX.p8 file (keep it OUTSIDE the repo).
ASC_KEY_PATH=/Users/you/secrets/AuthKey_XXXXXXXXXX.p8
